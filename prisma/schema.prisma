// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model EmailBatch {
  id          String      @id @default(cuid())
  name        String?    
  createdAt   DateTime    @default(now())

  emails      EmailSent[]
}

model EmailSent {
  id          String      @id @default(cuid())
  trackingId  String      @unique @default(cuid())
  recipient   String
  subject     String?
  createdAt   DateTime    @default(now())

  batchId     String?
  batch       EmailBatch? @relation(fields: [batchId], references: [id])

  opens       EmailOpen[]
}

model EmailOpen {
  id             String     @id @default(cuid())
  emailSentId    String
  emailSent      EmailSent  @relation(fields: [emailSentId], references: [id])
  clientIp       String?
  country        String?
  city           String?
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  device         String?
  userAgent      String?
  openedAt       DateTime   @default(now())
}